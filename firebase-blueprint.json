{
  "entities": {
    "PartyDetails": {
      "title": "Party Details",
      "description": "Details of a party (individual or representative) in the contract.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "profession": { "type": "string" },
        "domicile": { "type": "string" },
        "idNumber": { "type": "string" },
        "cui": { "type": "string" },
        "isRepresenting": { "type": "boolean" },
        "role": { "type": "string" },
        "entityName": { "type": "string" },
        "notaryName": { "type": "string" },
        "actDate": { "type": "string" },
        "regNumber": { "type": "string" },
        "regFolio": { "type": "string" },
        "regBook": { "type": "string" }
      },
      "required": ["name", "age", "maritalStatus", "profession", "domicile", "idNumber", "cui", "isRepresenting"]
    },
    "Policy": {
      "title": "Policy",
      "description": "Details of a policy being counter-guaranteed.",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "amountInWords": { "type": "string" }
      },
      "required": ["number", "type", "amount", "amountInWords"]
    },
    "CounterGuarantee": {
      "title": "Counter Guarantee",
      "description": "The main document data for a counter-guarantee.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contractDate": { "type": "string", "format": "date" },
        "principal": { "$ref": "PartyDetails" },
        "guarantors": {
          "type": "array",
          "items": { "$ref": "PartyDetails" }
        },
        "policies": {
          "type": "array",
          "items": { "$ref": "Policy" }
        },
        "notificationAddress": { "type": "string" },
        "beneficiaryName": { "type": "string" },
        "signatureNames": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "contractDate", "principal", "policies", "notificationAddress", "beneficiaryName", "signatureNames", "createdAt"]
    },
    "Template": {
      "title": "Document Template",
      "description": "HTML template for a specific contract type.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "content"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Saved party details for autocomplete.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "party": { "$ref": "PartyDetails" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "party", "createdAt"]
    }
  },
  "firestore": {
    "/counterGuarantees/{docId}": {
      "schema": "CounterGuarantee",
      "description": "Collection of counter-guarantee documents."
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Collection of document templates."
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of saved contacts."
    }
  }
}
