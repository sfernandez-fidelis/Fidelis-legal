rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for counter-guarantees
    match /counterGuarantees/{docId} {
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidCounterGuarantee(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == resource.data.userId &&
                      isValidCounterGuarantee(request.resource.data);
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Rules for templates
    match /templates/{templateId} {
      // Allow any authenticated user to read and update templates for now (acting as admins)
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidTemplate(request.resource.data);
    }

    // Rules for contacts
    match /contacts/{contactId} {
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidContact(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == resource.data.userId &&
                      isValidContact(request.resource.data);
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Validation functions
    function isValidCounterGuarantee(data) {
      return data.keys().hasAll(['userId', 'contractDate', 'principal', 'policies', 'notificationAddress', 'beneficiaryName', 'signatureNames', 'createdAt']) &&
             data.userId is string &&
             data.contractDate is string &&
             data.notificationAddress is string &&
             data.notificationAddress.size() < 500 &&
             data.beneficiaryName is string &&
             data.beneficiaryName.size() < 200;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['type', 'content']) &&
             data.type is string &&
             data.content is string;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['userId', 'party', 'createdAt']) &&
             data.userId is string &&
             data.party is map;
    }
  }
}
